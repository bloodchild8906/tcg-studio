{
  // Used to type-check vite.config.ts only. Project references require emit;
  // we redirect declaration output into node_modules/.cache so it never lands
  // in source control.
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "./node_modules/.cache/tsbuildinfo-node"
  },
  "include": ["vite.config.ts"]
}
