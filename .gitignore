# Secrets — NEVER commit. Keep this list explicit so a stray match
# doesn't sneak through (e.g. someone names a config `.env.prod` thinking
# the `.env.*.local` rule covers it — it doesn't).
deploy/.env
deploy/.env.prod
deploy/.env.production
deploy/.secrets.local
*.secrets.local
*.private.key
*.pem
.gcloud/
gha-deploy.key
gha-deploy.key.pub

